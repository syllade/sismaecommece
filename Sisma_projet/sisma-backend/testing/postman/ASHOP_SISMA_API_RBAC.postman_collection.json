{
  "info": {
    "_postman_id": "2ef4f900-2f8d-47af-96a8-ashopsisma-rbac",
    "name": "ASHOP SISMA API RBAC",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 - Auth",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": "{{base_url}}/api/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin login 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Role admin returned', function () { pm.expect(json.user.role).to.eql('admin'); });",
                  "pm.collectionVariables.set('admin_token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Supplier",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{supplier_email}}\",\n  \"password\": \"{{supplier_password}}\"\n}"
            },
            "url": "{{base_url}}/api/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Supplier login 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Role supplier returned', function () { pm.expect(json.user.role).to.eql('supplier'); });",
                  "pm.collectionVariables.set('supplier_token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Delivery",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{delivery_email}}\",\n  \"password\": \"{{delivery_password}}\"\n}"
            },
            "url": "{{base_url}}/api/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Delivery login 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Role delivery returned', function () { pm.expect(json.user.role).to.eql('delivery'); });",
                  "pm.collectionVariables.set('delivery_token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Client",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{client_email}}\",\n  \"password\": \"{{client_password}}\"\n}"
            },
            "url": "{{base_url}}/api/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Client login 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Role client returned', function () { pm.expect(json.user.role).to.eql('client'); });",
                  "pm.collectionVariables.set('client_token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "10 - Admin",
      "item": [
        {
          "name": "Admin - List Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": "{{base_url}}/api/admin/orders?per_page=20&page=1"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin list orders 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Admin - Bulk Assign",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_ids\": [{{admin_order_id_1}}, {{admin_order_id_2}}],\n  \"delivery_person_id\": {{admin_delivery_person_id}}\n}"
            },
            "url": "{{base_url}}/api/admin/orders/bulk-assign"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Admin bulk assign 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "20 - Supplier",
      "item": [
        {
          "name": "Supplier - List Own Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{supplier_token}}" }
            ],
            "url": "{{base_url}}/api/supplier/orders?page=1&per_page=20"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Supplier list orders 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Supplier - Update Own Order Status",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{supplier_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"prepared\"\n}"
            },
            "url": "{{base_url}}/api/supplier/orders/{{supplier_own_order_id}}/status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Supplier update status 200 or 409', function () { pm.expect([200,409]).to.include(pm.response.code); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "NEGATIVE - Supplier Access Other Supplier Order (403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{supplier_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"prepared\"\n}"
            },
            "url": "{{base_url}}/api/supplier/orders/{{supplier_forbidden_order_id}}/status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Supplier forbidden order is 403', function () { pm.response.to.have.status(403); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "30 - Delivery",
      "item": [
        {
          "name": "Delivery - List Assigned Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{delivery_token}}" }
            ],
            "url": "{{base_url}}/api/delivery/orders?page=1&per_page=20"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Delivery list orders 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delivery - Mark Delivered",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{delivery_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"proof_photo_url\": \"delivery-proofs/mock-proof.jpg\",\n  \"proof_signature\": \"base64-signature\"\n}"
            },
            "url": "{{base_url}}/api/delivery/orders/{{delivery_assigned_order_id}}/delivered"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Delivery delivered 200 or 409', function () { pm.expect([200,409]).to.include(pm.response.code); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "NEGATIVE - Delivery Access Admin Orders (403)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{delivery_token}}" }
            ],
            "url": "{{base_url}}/api/admin/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Delivery forbidden on admin route 403', function () { pm.response.to.have.status(403); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "40 - Client",
      "item": [
        {
          "name": "Client - List Own Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "url": "{{base_url}}/api/client/orders?page=1&per_page=20"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Client list own orders 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "NEGATIVE - Client Try Admin Update Order (403)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{client_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"cancelled\"\n}"
            },
            "url": "{{base_url}}/api/admin/orders/{{client_forbidden_order_id}}/status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Client forbidden update is 403', function () { pm.response.to.have.status(403); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "50 - Security Negative",
      "item": [
        {
          "name": "NEGATIVE - Expired/Invalid Token (401)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{expired_token}}" }
            ],
            "url": "{{base_url}}/api/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Invalid token returns 401', function () { pm.response.to.have.status(401); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ],
